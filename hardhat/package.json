{
  "name": "senza-hardhat",
  "version": "0.1.0",
  "private": true,
  "description": "Hardhat workspace for Senza wallet helper contracts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./types ./deployments.json",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --network hardhat --no-deploy",
    "deploy:localhost": "hardhat deploy --network localhost",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "export:deployments": "hardhat run --network localhost scripts/export-deployments.ts",
    "export:deployments:sepolia": "hardhat run --network sepolia scripts/export-deployments.ts"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.3.1",
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.4",
    "hardhat-deploy": "^0.11.45",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
